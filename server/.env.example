# Cosmos DB (MongoDB API)
MONGODB_URI=mongodb://account:key@host:10255/?ssl=true&replicaSet=globaldb
MONGODB_DB=auris

# Auth
ADMIN_KEY=change-me-admin-key

# Groq AI reports
GROQ_API_KEY=

# Twilio WhatsApp alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Re-ID worker (optional GCP)
REID_ENABLED=false
REID_SIMILARITY_THRESHOLD=0.7

# Server
HOST=0.0.0.0
PORT=8000

# CORS origins (Azure deployment)
CORS_ORIGINS=https://auris.skymlabs.com,https://hq.skymlabs.com
